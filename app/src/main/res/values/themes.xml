<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Aboneliklerim" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_indigo</item>
        <item name="colorPrimaryVariant">@color/primary_indigo</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary_indigo</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:textCursorDrawable">@drawable/cursor_purple</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textColorPrimary">@color/text_main</item>
        <item name="android:textColorSecondary">@color/text_sub</item>
        <item name="android:textColorHint">@color/text_sub</item>
        <item name="android:editTextColor">@color/text_main</item>
        <item name="colorAccent">@color/primary_indigo</item>
        <item name="android:colorAccent">@color/primary_indigo</item>
        <item name="colorControlActivated">@color/primary_indigo</item>
    </style>

    <style name="Theme.Aboneliklerim.NoActionBar" parent="Theme.Aboneliklerim">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.Aboneliklerim.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_main</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.Aboneliklerim.NoActionBar</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <style name="SpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:popupBackground">@color/surface_main</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="PurpleDatePickerTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/primary_indigo</item>
        <item name="colorAccent">@color/primary_indigo</item>
        <item name="android:headerBackground">@color/primary_indigo</item>
        <item name="android:dayOfWeekBackground">@color/primary_indigo</item>
        <item name="android:buttonBarButtonStyle">@style/DialogButtonStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogButtonStyle</item>
    </style>

    <style name="DialogButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/purple_500</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">#336200EE</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">9sp</item>
    </style>
    <style name="Theme.Aboneliklerim.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@color/surface_main</item>
        <item name="colorPrimary">@color/primary_indigo</item>
        <item name="colorAccent">@color/primary_indigo</item>
        <item name="android:colorAccent">@color/primary_indigo</item>
        <item name="colorControlActivated">@color/primary_indigo</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>
</resources>
