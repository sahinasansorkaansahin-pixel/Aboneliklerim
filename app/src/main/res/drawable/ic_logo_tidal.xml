<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">
    <!-- Tidal Pure Black Circle Background -->
    <path
        android:fillColor="#000000"
        android:pathData="M24,24m-22,0a22,22 0,1,1 44,0a22,22 0,1,1 -44,0" />
    
    <!-- Rotated Group to form the 4 interconnected diamonds -->
    <group
        android:rotation="45"
        android:pivotX="24"
        android:pivotY="24">
        
        <!-- Top Square (becomes Top Diamond) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M21.5,14 H26.5 V19 H21.5 Z" />
            
        <!-- Left Square (becomes Left Diamond) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M14,21.5 H19 V26.5 H14 Z" />
            
        <!-- Right Square (becomes Right Diamond) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M29,21.5 H34 V26.5 H29 Z" />
            
        <!-- Bottom Square (becomes Bottom Diamond) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M21.5,29 H26.5 V34 H21.5 Z" />
            
    </group>
</vector>
