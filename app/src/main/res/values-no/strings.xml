    <string name="onboarding_title_1">Velkommen til Mine abonnementer</string>
    <string name="onboarding_desc_1">Administrer alle dine digitale og fysiske abonnementer under ett tak.</string>
    <string name="onboarding_title_2">Gå aldri glipp av en betaling</string>
    <string name="onboarding_desc_2">Bli varslet før betalingsdager med automatiske påminnelser.</string>
    <string name="onboarding_title_3">Smart mørk modus</string>
    <string name="onboarding_desc_3">Et moderne grensesnitt som tilpasser seg tiden på dagen eller dine preferanser.</string>
    <string name="onboarding_title_4">Detaljert statistikk</string>
    <string name="onboarding_desc_4">Analyser utgiftene dine med månedlige og årlige diagrammer for å spare penger.</string>
    <string name="onboarding_title_5">Global støtte og valutasporing</string>
