    <string name="onboarding_title_1">Velkommen til Mine abonnementer</string>
    <string name="onboarding_desc_1">Administrer alle dine digitale og fysiske abonnementer under ét tag.</string>
    <string name="onboarding_title_2">Gå aldrig glip af en betaling</string>
    <string name="onboarding_desc_2">Få besked før betalingsdage med automatiske påmindelser.</string>
    <string name="onboarding_title_3">Smart mørk tilstand</string>
    <string name="onboarding_desc_3">En moderne grænseflade, der tilpasser sig tidspunktet på dagen eller dine præferencer.</string>
    <string name="onboarding_title_4">Detaljeret statistik</string>
    <string name="onboarding_desc_4">Analyser dit forbrug med månedlige og årlige diagrammer for at spare penge.</string>
    <string name="onboarding_title_5">Global support og valutasporing</string>
    <string name="onboarding_desc_5">Administrer abonnementer på mange sprog og valutaer. Spor realtidskurser integreret for alle understøttede lande.</string>
    <string name="onboarding_title_6">Avanceret tagging</string>
    <string name="onboarding_desc_6">Kategoriser dine abonnementer for bedre at administrere dine udgifter.</string>
    <string name="onboarding_title_7">Lokal &amp; Cloud Backup</string>
    <string name="onboarding_desc_7">Sikkerhedskopier dine data både lokalt på din enhed og i skyen for at få adgang til dem fra alle dine enheder.</string>
    <string name="onboarding_title_8">Start nu!</string>
    <string name="onboarding_desc_8">Styr dine abonnementer nu ved at tilføje dit første.</string>
    <string name="onboarding_title_9">Deling af omkostninger</string>
    <string name="onboarding_desc_9">Opdel abonnementsomkostninger med venner eller familie og send hurtige betalingspåmindelser med et enkelt klik!</string>
    <string name="onboarding_title_10">Bliv Premium og annoncefri</string>
    <string name="onboarding_desc_10">Nyd ubegrænset sikkerhedskopiering, realtidskurser i realtid, avanceret omkostningsopdeling og en helt reklamefri premium-oplevelse.</string>
