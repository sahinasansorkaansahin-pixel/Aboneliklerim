<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true"
    android:layout_marginBottom="8dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Logo, Title, Trend Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/imgPlatformLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_logo_prime_video"
                android:scaleType="centerInside"
                android:contentDescription="Platform Logo" />

            <TextView
                android:id="@+id/tvPlatformName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Amazon Prime Video" />

            <!-- Price Trend Badge -->
            <TextView
                android:id="@+id/tvTrendBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_shared_contact_pill"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Stable" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_secondary"
            android:layout_marginBottom="12dp" />

        <!-- Middle Section: Dynamic Plans List -->
        <LinearLayout
            android:id="@+id/plansContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            tools:layout_height="60dp">
            <!-- Programmatically added plans will appear here -->
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_secondary"
            android:layout_marginBottom="12dp" />

        <!-- Bottom Row: Link to Website -->
        <LinearLayout
            android:id="@+id/btnOpenWeb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/open_website"
                android:textColor="@color/primary_indigo"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right_bold"
                android:tint="@color/primary_indigo" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
