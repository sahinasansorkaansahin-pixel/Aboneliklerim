<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface_main"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Color Bar -->
        <View
            android:id="@+id/viewColor"
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="#6366f1" />

        <!-- Icon Circle -->
        <TextView
            android:id="@+id/tvSubIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/circle_color"
            android:gravity="center"
            android:text="N"
            android:textColor="@color/text_main"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvSubName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:scrollHorizontally="true" />
                <ImageView
                    android:id="@+id/ivNotificationBell"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_bell"
                    app:tint="@color/primary_indigo"
                    android:visibility="gone" />
            </LinearLayout>

                <TextView
                    android:id="@+id/tvSubPeriod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Aylık • Eğlence"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeStepGranularity="1sp" />

            <TextView
                android:id="@+id/tvSubTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tags"
                android:textColor="@color/primary_indigo"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_price_tag"
                android:drawablePadding="4dp"
                android:drawableTint="@color/primary_indigo"
                android:visibility="gone"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="8sp"
                app:autoSizeMaxTextSize="12sp"
                app:autoSizeStepGranularity="1sp" />
        </LinearLayout>

        <!-- Price and Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            android:gravity="end">
            <TextView android:id="@+id/tvPrice" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0.00 TRY" android:textColor="@color/text_main" android:textSize="16sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/tvRemainingDays" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/days_remaining" android:textColor="@color/primary_indigo" android:textSize="11sp"
                android:layout_marginTop="2dp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
