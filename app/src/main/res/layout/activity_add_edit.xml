<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardBackgroundColor="@color/surface_main"
                app:cardCornerRadius="32dp"
                app:strokeColor="@color/primary_indigo"
                app:strokeWidth="3dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:paddingTop="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnBack"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/back_button_bg"
                            android:src="@drawable/ic_back_chevron"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:tint="@color/text_main"
                            android:contentDescription="@string/back" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/new_subscription"
                            android:textColor="@color/text_main"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginEnd="36dp"
                            android:letterSpacing="0.02" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="40dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_gravity="center">

                            <EditText
                                android:id="@+id/etPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:hint="0,00"
                                android:inputType="numberDecimal"
                                android:textColor="@color/text_main"
                                android:textColorHint="@color/text_sub"
                                android:textSize="56sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:textCursorDrawable="@drawable/cursor_purple" />

                            <TextView
                                android:id="@+id/tvCurrencySymbol"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₺"
                                android:textColor="@color/text_main"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginStart="4dp"
                                android:layout_marginBottom="10dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="100dp"
                            android:layout_height="2dp"
                            android:layout_marginVertical="16dp"
                            android:background="@color/primary_indigo"
                            android:alpha="0.6"/>

                        <TextView
                            android:id="@+id/tvCurrencyLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRY"
                            android:textColor="@color/text_main"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

            <!-- Name Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/name"
                android:textColor="@color/text_main"
                android:textSize="15sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/input_bg"
                android:hint="@string/name"
                android:padding="16dp"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_sub"
                android:maxLines="1"
                android:ellipsize="end" />



            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal">
                    
                    <TextView
                        android:id="@+id/tvTabRegular"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/regular"
                        android:textColor="#730692"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvTabOneTime"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/one_time"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#44FFFFFF">
                    <View
                        android:id="@+id/tabIndicator"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="#730692" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Regular Billing Details -->
            <LinearLayout
                android:id="@+id/layoutRegular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <!-- Period Selection (Every X Days/Months) -->
                <LinearLayout
                    android:id="@+id/layoutPeriodSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/period"
                        android:textColor="@color/text_main"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/every"
                            android:textColor="@color/text_main"
                            android:textSize="16sp"
                            android:layout_marginEnd="12dp" />

                        <EditText
                            android:id="@+id/etPeriodValue"
                            android:layout_width="80dp"
                            android:layout_height="56dp"
                            android:background="@drawable/input_bg"
                            android:text="1"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="2"
                            android:textColor="@color/text_main" />

                        <Spinner
                            android:id="@+id/spinnerPeriod"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/input_bg"
                            style="@style/SpinnerStyle" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Shared Date Field (Labels change based on tab) -->
                <TextView
                    android:id="@+id/tvDateLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/first_payment"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDateValue"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="@string/today"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="@string/notification"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/time"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">
                
                <Spinner
                    android:id="@+id/spinnerNotify"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="2"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/input_bg"
                    style="@style/SpinnerStyle" />

                <TextView
                    android:id="@+id/tvNotifyTime"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_bg"
                    android:gravity="center"
                    android:text="09:00"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_cost_sharing"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shared_with"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shared_with_desc"
                android:textColor="@color/text_sub"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:id="@+id/layoutSharedRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input_bg"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/btnMinusShared"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="-"
                        android:gravity="center"
                        android:textSize="28sp"
                        android:textColor="@color/primary_indigo"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvSharedCount"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:gravity="center"
                        android:textColor="@color/text_main"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnPlusShared"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="+"
                        android:gravity="center"
                        android:textSize="24sp"
                        android:textColor="@color/primary_indigo"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Semi-transparent Lock Overlay with matching rounded corners -->
                <FrameLayout
                    android:id="@+id/layoutSharedLockOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/locked_overlay_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/white" />
                </FrameLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/layoutSharedContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/containerSharedContacts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tvSharedContactError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#ef4444"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone"
                    android:text="@string/duplicate_contact_warning" />

                <TextView
                    android:id="@+id/btnAddSharedContact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_contact"
                    android:textColor="#730692"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingVertical="8dp"
                    android:layout_gravity="center_horizontal"
                    android:background="?attr/selectableItemBackground" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/color"
                android:textColor="@color/text_main"
                android:textSize="15sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvColorPickerTrigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/input_bg"
                android:padding="16dp"
                android:text="@string/select_color_msg"
                android:textColor="@color/text_main"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_method"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/optional"
                    android:textColor="@color/text_main"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
            <EditText
                android:id="@+id/etPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/input_bg"
                android:hint="@string/payment_method"
                android:padding="16dp"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_sub"
                android:maxLines="1"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/note"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/optional"
                    android:textColor="@color/text_main"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/input_bg"
                android:hint="@string/hint_desc_example"
                android:padding="16dp"
                android:gravity="top"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_sub" />

            <LinearLayout
                android:id="@+id/btnTagsTrigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_price_tag"
                    android:tint="@color/primary_indigo" />
                <TextView
                    android:id="@+id/btnTagsTriggerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                     android:text="@string/add_tag"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:backgroundTint="#730692"
                android:text="@string/save_subscription"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:cornerRadius="32dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
</LinearLayout>
