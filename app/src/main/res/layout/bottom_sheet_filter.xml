<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingBottom="32dp"
    android:paddingTop="12dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:background="#730692" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/view_options"
        android:textColor="@color/text_main"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Time Remaining Row -->
    <LinearLayout
        android:id="@+id/rowToggleDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingVertical="10dp"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_time_remaining"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvToggleDateStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Tags Row -->
    <LinearLayout
        android:id="@+id/rowToggleTags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingVertical="10dp"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_tags"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvToggleTagsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Archive Row -->
    <LinearLayout
        android:id="@+id/rowToggleArchive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingVertical="10dp"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_archived"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvArchiveStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Payment Type Filter (Unified) -->
    <LinearLayout
        android:id="@+id/rowTogglePaymentType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingVertical="10dp"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_payment_type_label"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvPaymentTypeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hepsi"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
