<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/more"
            android:textColor="@color/text_main"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_options"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="140dp"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        android:scrollbarSize="4dp"
        android:scrollbarStyle="outsideOverlay"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Account Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGoogleWrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_main"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="8dp">
                    
                    <LinearLayout android:id="@+id/rowGoogleSignIn" android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/senkronize"
                            app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/login_with_google" android:textColor="@color/text_main" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textColor="@color/text_secondary" android:textSize="24sp"/>
                    </LinearLayout>

                    <View android:id="@+id/dividerGoogleGuest" android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout android:id="@+id/rowGuestSignIn" android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_guest_user"
                            app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/login_as_guest" android:textColor="@color/text_main" android:textSize="16sp"/>
                        <!-- Lock Icon for Non-Premium Users -->
                        <ImageView android:id="@+id/ivGuestLock"
                            android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_lock" app:tint="#8E8E93"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone"/>
                        <TextView android:id="@+id/tvGuestArrow" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textColor="@color/text_secondary" android:textSize="24sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layoutLoginStatus" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:padding="12dp" android:visibility="gone">
                        <ProgressBar android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="12dp"
                             android:indeterminateTint="@color/primary_indigo"/>
                        <TextView android:id="@+id/tvLoginStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/logging_in" android:textColor="@color/text_main" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardUserInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/surface_main"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivUserProfile"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginBottom="12dp"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImage" />

                    <TextView android:id="@+id/tvWelcomeMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_simple"
                        android:textColor="@color/text_main"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="12sp"
                        app:autoSizeMaxTextSize="18sp"
                        app:autoSizeStepGranularity="1sp"/>
                    
                    <TextView android:id="@+id/tvUserEmail" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="email@example.com" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_marginTop="4dp" android:gravity="center"/>
                    
                    <LinearLayout android:id="@+id/layoutCloudButtons" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center" android:layout_marginTop="16dp">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUploadMore"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/backup_to_cloud"
                                android:layout_marginEnd="4dp"
                                app:cornerRadius="12dp"
                                android:backgroundTint="@color/primary_indigo"
                                android:textSize="12sp"
                                android:padding="0dp"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDownloadMore"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/restore_from_cloud"
                                android:layout_marginStart="4dp"
                                app:cornerRadius="12dp"
                                android:backgroundTint="@color/primary_indigo"
                                android:textSize="12sp"
                                android:padding="0dp"/>
                        </LinearLayout>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDeleteCloudMore"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/delete_cloud_data"
                            android:layout_marginTop="8dp"
                            app:cornerRadius="12dp"
                            android:backgroundTint="@color/error_red"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:padding="0dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton 
                        android:id="@+id/btnLogoutMore" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content"
                        android:text="@string/logout" 
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/error_red"
                        android:textColor="@color/white"
                        app:cornerRadius="12dp"
                        android:textSize="13sp"/>

                    <ProgressBar android:id="@+id/pbSyncMore" android:layout_width="24dp" android:layout_height="24dp"
                        android:layout_marginTop="8dp" android:visibility="gone"
                        android:indeterminateTint="@color/primary_indigo"/>

                    <TextView android:id="@+id/tvSyncStatusMore" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:visibility="gone" android:gravity="center"/>

                    <View android:id="@+id/dividerAccountLocal" android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginTop="12dp"/>

                    <LinearLayout android:id="@+id/layoutLocalBackupActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <LinearLayout android:id="@+id/rowLocalBackup" android:layout_width="match_parent" android:layout_height="48dp"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:paddingHorizontal="8dp"
                            android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="@string/local_backup_now" android:textColor="@color/text_main" android:textSize="15sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="💾" android:textSize="16sp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/rowLocalRestore" android:layout_width="match_parent" android:layout_height="48dp"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:paddingHorizontal="8dp"
                            android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="@string/local_restore" android:textColor="@color/text_main" android:textSize="15sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📥" android:textSize="16sp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/rowLocalDelete" android:layout_width="match_parent" android:layout_height="48dp"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:paddingHorizontal="8dp"
                            android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="@string/local_delete" android:textColor="@color/error_red" android:textSize="15sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🗑️" android:textSize="16sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Premium Banner -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPremium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_premium_button"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_diamond_faceted"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/premium_get_service"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center_vertical"/>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right_bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Appearance Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appearance"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_main"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <!-- Theme & Language -->
                    <LinearLayout android:id="@+id/rowTheme" android:layout_width="match_parent" android:layout_height="48dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_dark_mode_purple" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/dark_mode" android:textColor="@color/text_main" android:textSize="15sp"/>
                        <TextView android:id="@+id/tvCurrentTheme" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/system_default" android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/rowLanguage" android:layout_width="match_parent" android:layout_height="48dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_language_purple" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/language" android:textColor="@color/text_main" android:textSize="15sp"/>
                        <TextView android:id="@+id/tvCurrentLanguage" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Türkçe" android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/rowDefaultCurrency" android:layout_width="match_parent" android:layout_height="48dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_price_tag" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/default_currency" android:textColor="@color/text_main" android:textSize="15sp"/>
                        <TextView android:id="@+id/tvCurrentDefaultCurrency" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TRY" android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="20sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginVertical="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- General & Tools -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/general"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_main"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="8dp">

                    <LinearLayout android:id="@+id/rowDateFormat" android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_date_format_purple" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/date_format" android:textColor="@color/text_main" android:textSize="16sp"/>
                        <TextView android:id="@+id/tvCurrentDateFormat" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="dd/MM/yyyy" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="24sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout android:id="@+id/rowRate" android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_rate_purple" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/rate_app" android:textColor="@color/text_main" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="24sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout android:id="@+id/rowShare" android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_share_purple" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/share_app" android:textColor="@color/text_main" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="24sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout android:id="@+id/rowTutorial" android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_help_purple" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/how_to_use" android:textColor="@color/text_main" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="24sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Currency Converter -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/currency_converter" android:textColor="@color/text_main" android:textSize="14sp"
                android:textStyle="bold" android:layout_marginStart="8dp" android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardCurrencyConverter"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" app:cardBackgroundColor="@color/surface_main" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <EditText android:id="@+id/etCurrencyAmount" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:background="@null" android:hint="1.00" android:inputType="numberDecimal"
                                android:textColor="@color/text_main" android:textSize="20sp" android:textStyle="bold" android:text="1"/>
                            <TextView android:id="@+id/tvBaseCurrencyCode" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TRY" android:textColor="@color/primary_indigo" android:textSize="16sp" android:textStyle="bold" android:layout_marginStart="8dp"
                                android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" android:padding="4dp"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginTop="12dp" android:layout_marginBottom="12dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:id="@+id/tvConvertedAmount" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="0.00" android:textColor="@color/text_main" android:textSize="20sp" android:textStyle="bold"/>
                            <TextView android:id="@+id/tvTargetCurrencyCode" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="USD" android:textColor="@color/text_secondary" android:textSize="16sp" android:textStyle="bold" android:layout_marginStart="8dp"
                                android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground" android:padding="4dp"/>
                        </LinearLayout>
                        <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnUpdateCurrency"
                            android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="16dp"
                            android:text="@string/update" android:textAllCaps="false" android:textColor="@android:color/white"
                            android:background="@drawable/bg_primary_button_small"/>
                    </LinearLayout>

                    <!-- Premium Lock Overlay for Converter -->
                    <LinearLayout
                        android:id="@+id/layoutConverterPremiumOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#EE0B0B14"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone">
                        <ImageView 
                            android:layout_width="40dp" 
                            android:layout_height="40dp" 
                            android:src="@drawable/ic_lock" 
                            app:tint="#8E8E93"/>
                        <TextView 
                            android:layout_width="wrap_content" 
                            android:layout_height="wrap_content" 
                            android:text="@string/premium_get_service" 
                            android:textColor="#8E8E93" 
                            android:textSize="14sp" 
                            android:textStyle="bold" 
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Streaming Prices Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:id="@+id/tvStreamingTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/streaming_prices" android:textColor="@color/text_main" android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardStreamingPrices"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" app:cardBackgroundColor="@color/surface_main" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">

                        <ImageView android:id="@+id/imgSelectedStreamingLogo"
                            android:layout_width="32dp" android:layout_height="32dp"
                            android:visibility="invisible"/>

                        <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spinnerStreamingPlatforms"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="12dp"
                            android:backgroundTint="@color/primary_indigo"/>

                        <TextView android:id="@+id/tvStreamingSelectedTrend"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:textSize="12sp" android:textStyle="bold"
                            android:paddingHorizontal="8dp" android:paddingVertical="4dp"
                            android:visibility="gone"/>

                        <ImageView android:id="@+id/imgSelectedStreamingBell"
                            android:layout_width="32dp" android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:padding="4dp"
                            android:src="@drawable/ic_bell"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layoutStreamingDetails"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginTop="12dp" android:layout_marginBottom="12dp"/>

                        <LinearLayout android:id="@+id/layoutStreamingSelectedPlans"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnOpenStreamingWeb"
                            android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="16dp"
                            android:text="@string/open_website" android:textAllCaps="false" android:textColor="@android:color/white"
                            android:background="@drawable/bg_primary_button_small"/>
                    </LinearLayout>
                </LinearLayout>
                
                <!-- Premium Lock Overlay for Streaming Prices -->
                <LinearLayout
                    android:id="@+id/layoutStreamingPremiumOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#EE0B0B14"
                    android:focusable="true"
                    android:clickable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <ImageView 
                        android:layout_width="40dp" 
                        android:layout_height="40dp" 
                        android:src="@drawable/ic_lock" 
                        app:tint="#8E8E93"/>
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="@string/premium_get_service" 
                        android:textColor="#8E8E93" 
                        android:textSize="14sp" 
                        android:textStyle="bold" 
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tester Area -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/tester_tools" android:textColor="@color/text_main" android:textSize="14sp"
                android:textStyle="bold" android:layout_marginStart="8dp" android:layout_marginTop="24dp" android:layout_marginBottom="8dp" />
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" app:cardBackgroundColor="@color/surface_main" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="8dp">
                    
                    <LinearLayout android:id="@+id/rowShowAdId" android:layout_width="match_parent" android:layout_height="48dp"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_price_tag" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/show_ad_id" android:textColor="@color/text_main" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="20sp"/>
                    </LinearLayout>
                    
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="8dp"/>
                    
                    <LinearLayout android:id="@+id/rowTogglePremium" android:layout_width="match_parent" android:layout_height="48dp"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp"
                        android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_diamond_faceted" app:tint="@color/primary_indigo"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"
                            android:text="@string/tester_premium_toggle" android:textColor="@color/text_main" android:textSize="15sp"/>
                        <TextView android:id="@+id/tvCurrentPremiumStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pasif" android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/text_secondary" android:textSize="20sp"/>
                    </LinearLayout>
                    
                </LinearLayout>
            </androidx.cardview.widget.CardView>



        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
