<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="2dp">

    <LinearLayout
        android:id="@+id/layoutWidgetContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/rounded_widget_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp">

        <!-- Color Bar -->
        <ImageView
            android:id="@+id/viewWidgetColorBar"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:layout_marginRight="14dp"
            android:src="@drawable/circle_color" />

        <!-- Icon -->
        <FrameLayout
            android:id="@+id/layoutWidgetIconArea"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginRight="14dp">

            <ImageView
                android:id="@+id/ivWidgetLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivWidgetLetterBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/circle_color" />

            <TextView
                android:id="@+id/tvWidgetLetterIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvWidgetSubName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_main"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:maxLines="1" />
                <ImageView
                    android:id="@+id/ivWidgetBellIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_bell"
                    android:layout_marginLeft="6dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvWidgetPeriod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1" />

            <!-- Category -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="1dp">
                <ImageView
                    android:id="@+id/ivWidgetTagIcon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_price_tag" />
                <TextView
                    android:id="@+id/tvWidgetCategoryName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary_indigo"
                    android:textSize="12sp"
                    android:layout_marginLeft="4dp"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Payment Method -->
            <LinearLayout
                android:id="@+id/layoutWidgetPaymentRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:id="@+id/viewWidgetPaymentDot"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:src="@drawable/circle_color" />
                <TextView
                    android:id="@+id/tvWidgetPaymentMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginLeft="4dp"
                    android:maxLines="1"
                    android:includeFontPadding="false"
                    android:gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right Side -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="right"
            android:layout_marginLeft="14dp">
            <TextView
                android:id="@+id/tvWidgetPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_main"
                android:textSize="17sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvWidgetDaysLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_indigo"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvWidgetEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/rounded_widget_bg"
        android:text="@string/no_upcoming_subs"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />
</RelativeLayout>