    <string name="onboarding_title_1">Willkommen bei „Meine Abonnements“.</string>
    <string name="onboarding_desc_1">Verwalten Sie alle Ihre digitalen und physischen Abonnements unter einem Dach.</string>
    <string name="onboarding_title_2">Verpassen Sie nie wieder eine Zahlung</string>
